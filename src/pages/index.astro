---
import Layout from '@layouts/Default.astro';
import { Card } from '@eliancodes/brutal-ui';
import { Button } from '@eliancodes/brutal-ui';
import { Pill } from '@eliancodes/brutal-ui';

const skills = [
  { name: 'Swift', category: 'language' },
  { name: 'SwiftUI', category: 'framework' },
  { name: 'UIKit', category: 'framework' },
  { name: 'Combine', category: 'framework' },
  { name: 'CoreData', category: 'framework' },
  { name: 'Git', category: 'tool' },
  { name: 'Xcode', category: 'tool' },
  { name: 'REST APIs', category: 'backend' },
  { name: 'Firebase', category: 'backend' },
];

const projects = [
  {
    name: 'Project One',
    description: 'A modern iOS app built with SwiftUI that helps users track their daily habits.',
    tech: ['SwiftUI', 'CoreData', 'Combine'],
    url: '#',
    color: '#ffe01b',
  },
  {
    name: 'Project Two',
    description: 'Native iOS application featuring real-time data synchronization and offline support.',
    tech: ['UIKit', 'Firebase', 'CoreData'],
    url: '#',
    color: '#ff7a1a',
  },
  {
    name: 'Project Three',
    description: 'E-commerce app with custom animations and seamless checkout experience.',
    tech: ['SwiftUI', 'REST APIs', 'Stripe'],
    url: '#',
    color: '#28c7ff',
  },
];
---

<Layout
  title='iOS Engineer Portfolio'
  pageTitle='iOS Engineer | Home'
  description='iOS Engineer specializing in Swift, SwiftUI, and native iOS development.'
>
  <main class='site-background'>
    <!-- Hero Section -->
    <section id='hero' class='p-6 md:p-12'>
      <div class='max-w-7xl mx-auto'>
        <Card color='#ffe01b'>
          <div class='grid lg:grid-cols-[1fr_auto] items-center gap-8 p-4 md:p-8'>
            <div class='flex flex-col items-start gap-6'>
              <h1 class='hero-name-title outfit font-bold'>
                <span class='hero-title-accent hero-name-text'>Oscar Cuadra Navarro</span>
              </h1>
              <p class='poppins text-xl md:text-2xl lg:text-3xl max-w-3xl'>
                I build beautiful, performant native iOS applications using Swift, SwiftUI, and UIKit.
                Passionate about creating exceptional user experiences.
              </p>
              <div class='flex gap-4 flex-wrap'>
                <Button href='#projects'>
                  View My Work &rarr;
                </Button>
                <Button href='#contact'>
                  Get In Touch
                </Button>
              </div>
            </div>
            <button
              class='hero-profile-button'
              type='button'
              aria-label='Spin profile photo'
            >
              <img
                src='/oscar-profile.jpeg'
                alt='Oscar Cuadra Navarro'
                class='hero-profile-image'
                loading='eager'
              />
            </button>
          </div>
        </Card>
      </div>
    </section>

    <!-- About Section -->
    <section id='about' class='p-6 md:p-12'>
      <div class='max-w-7xl mx-auto grid md:grid-cols-2 gap-8'>
        <Card color='#8FCE00'>
          <div class='p-2 md:p-4'>
            <p class='section-kicker'>Profile</p>
            <h2 class='text-3xl md:text-5xl lg:text-6xl mb-6 dm-serif'>
              About Me
            </h2>
            <p class='poppins text-lg md:text-xl mb-6 max-w-xl'>
              I'm Oscar, an iOS engineer focused on building polished native experiences
              with Swift, SwiftUI and UIKit. I care about clean architecture, smooth
              interactions and product details that make apps feel reliable.
            </p>
            <div class='grid sm:grid-cols-3 gap-3'>
              <div class='mini-stat'>
                <span class='mini-stat-value'>3+</span>
                <span class='mini-stat-label'>Years iOS</span>
              </div>
              <div class='mini-stat'>
                <span class='mini-stat-value'>UIKit</span>
                <span class='mini-stat-label'>Production UI</span>
              </div>
              <div class='mini-stat'>
                <span class='mini-stat-value'>SwiftUI</span>
                <span class='mini-stat-label'>Modern screens</span>
              </div>
            </div>
          </div>
        </Card>

        <Card color='#ff7a1a'>
          <div class='p-2 md:p-4'>
            <p class='section-kicker'>Craft</p>
            <h2 class='text-3xl md:text-5xl lg:text-6xl mb-6 dm-serif'>
              What I Do
            </h2>
            <div class='space-y-4'>
              <article class='capability-row'>
                <span class='capability-icon i-uil-mobile-android'></span>
                <div>
                  <h3 class='outfit text-2xl font-bold'>Native iOS</h3>
                  <p class='poppins text-base md:text-lg'>
                    Swift apps built with maintainable architecture and production-quality UI.
                  </p>
                </div>
              </article>
              <article class='capability-row'>
                <span class='capability-icon i-uil-brush-alt'></span>
                <div>
                  <h3 class='outfit text-2xl font-bold'>Product UI</h3>
                  <p class='poppins text-base md:text-lg'>
                    UIKit and SwiftUI screens with attention to flows, states and visual polish.
                  </p>
                </div>
              </article>
              <article class='capability-row'>
                <span class='capability-icon i-uil-tachometer-fast'></span>
                <div>
                  <h3 class='outfit text-2xl font-bold'>Quality & Performance</h3>
                  <p class='poppins text-base md:text-lg'>
                    Debugging, profiling and delivery workflows for apps that need to stay sharp.
                  </p>
                </div>
              </article>
            </div>
          </div>
        </Card>
      </div>
    </section>

    <!-- Skills Section -->
    <section id='skills' class='p-6 md:p-12'>
      <div class='max-w-7xl mx-auto'>
        <Card color='#28c7ff'>
          <h2 class='text-3xl md:text-5xl lg:text-6xl mb-8 dm-serif'>
            Skills & Technologies
          </h2>
          <div class='flex gap-3 flex-wrap'>
            {
              skills.map((skill) => (
                <Pill>
                  <span class='sanchez text-sm md:text-base'>{skill.name}</span>
                </Pill>
              ))
            }
          </div>
        </Card>
      </div>
    </section>

    <!-- Projects Section -->
    <section id='projects' class='p-6 md:p-12'>
      <div class='max-w-7xl mx-auto'>
        <h2 class='text-4xl md:text-6xl lg:text-7xl mb-8 dm-serif text-center'>
          Featured Projects
        </h2>
        <div class='grid md:grid-cols-2 lg:grid-cols-3 gap-8'>
          {
            projects.map((project) => (
              <Card color={project.color}>
                <div class='flex flex-col h-full p-4'>
                  <h3 class='text-2xl md:text-3xl lg:text-4xl mb-4 outfit font-bold'>
                    {project.name}
                  </h3>
                  <p class='poppins text-base md:text-lg mb-6 flex-grow'>
                    {project.description}
                  </p>
                  <div class='flex gap-2 flex-wrap mb-4'>
                    {project.tech.map((tech) => (
                      <Pill>
                        <span class='sanchez text-xs md:text-sm'>{tech}</span>
                      </Pill>
                    ))}
                  </div>
                  <Button href={project.url} target='_blank'>
                    View Project &rarr;
                  </Button>
                </div>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section id='contact' class='p-6 md:p-12'>
      <div class='max-w-4xl mx-auto'>
        <Card color='#ee4cff'>
          <div class='text-center p-8'>
            <h2 class='text-4xl md:text-6xl lg:text-7xl mb-6 dm-serif'>
              Let's Work Together
            </h2>
            <p class='poppins text-lg md:text-xl mb-8 max-w-2xl mx-auto'>
              I'm always interested in hearing about new projects and opportunities.
              Whether you have a question or just want to say hi, feel free to reach out!
            </p>
            <div class='flex gap-4 justify-center flex-wrap'>
              <Button href='https://www.linkedin.com/in/oscar-cuadra-navarro-4bbb5743/?locale=en' target='_blank'>
                Contact on LinkedIn
              </Button>
              <Button href='https://www.linkedin.com/in/oscar-cuadra-navarro-4bbb5743/?locale=en' target='_blank'>
                LinkedIn
              </Button>
              <Button href='https://github.com/Rokkrs' target='_blank'>
                GitHub
              </Button>
            </div>
          </div>
        </Card>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const profileButton = document.querySelector('.hero-profile-button');

    profileButton?.addEventListener('click', () => {
      profileButton.classList.remove('is-spinning');
      window.requestAnimationFrame(() => {
        profileButton.classList.add('is-spinning');
      });
    });

    profileButton?.addEventListener('animationend', () => {
      profileButton.classList.remove('is-spinning');
    });
  });
</script>
