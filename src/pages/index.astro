---
import Layout from '@layouts/Default.astro';
import { Card } from '@eliancodes/brutal-ui';
import { Button } from '@eliancodes/brutal-ui';
import { Pill } from '@eliancodes/brutal-ui';

const skills = [
  { name: 'Swift', category: 'language' },
  { name: 'SwiftUI', category: 'framework' },
  { name: 'UIKit', category: 'framework' },
  { name: 'UIKit to SwiftUI migrations', category: 'architecture' },
  { name: 'Combine', category: 'framework' },
  { name: 'CoreData', category: 'framework' },
  { name: 'GraphQL/Apollo', category: 'backend' },
  { name: 'Architecture', category: 'architecture' },
  { name: 'Observability', category: 'platform' },
  { name: 'AI Agents', category: 'ai' },
  { name: 'AI-assisted development', category: 'ai' },
  { name: 'Technical presentations', category: 'leadership' },
  { name: 'Cross-team initiatives', category: 'leadership' },
  { name: 'Product/UX thinking', category: 'product' },
  { name: 'Git', category: 'tool' },
  { name: 'Xcode', category: 'tool' },
  { name: 'Codex', category: 'tool' },
  { name: 'Cursor', category: 'tool' },
  { name: 'Claude', category: 'tool' },
  { name: 'REST APIs', category: 'backend' },
  { name: 'Firebase', category: 'backend' },
];

const focusAreas = [
  {
    title: 'Mobile systems modernization',
    description:
      'Migrating UIKit surfaces into SwiftUI, improving architecture, and keeping production apps maintainable while teams continue shipping.',
    icon: 'i-uil-mobile-android',
  },
  {
    title: 'AI-assisted engineering',
    description:
      'Experimenting with coding agents, Claude, Cursor and Codex to turn specs, product context and developer intent into safer implementation loops.',
    icon: 'i-uil-robot',
  },
  {
    title: 'Product-aware execution',
    description:
      'Connecting technical choices with user experience, observability, cross-team collaboration and clear technical storytelling.',
    icon: 'i-uil-analysis',
  },
];

const projects = [
  {
    name: 'Expedia Group - Vrbo Owner',
    companyLogo: 'Expedia Group',
    logoClass: 'project-logo-expedia',
    logoIcon: 'expedia',
    role: 'iOS Engineer',
    description: 'Contributing to a global owner-facing iOS product at Expedia Group, building SwiftUI experiences and integrating GraphQL, RESTful services, Firebase and observability tooling to support reliable delivery for users worldwide.',
    tech: ['SwiftUI', 'GraphQL', 'RESTful APIs', 'Firebase', 'Splunk', 'DataDog'],
    image: '/vrbo-owner-preview.png',
    color: '#ffe01b',
  },
  {
    name: 'Banco Falabella',
    companyLogo: 'Banco Falabella',
    logoClass: 'project-logo-falabella',
    logoIcon: 'falabella',
    role: 'Full Stack Developer',
    description: 'Contributed to a large-scale banking modernization effort, migrating legacy Java servlet workflows into a more maintainable Angular 10 and Node.js platform backed by Oracle services, with ownership across delivery, maintenance and deployments.',
    tech: ['Angular 10', 'Node.js', 'Java Servlets', 'Oracle', 'Deployments'],
    image: '/falabella-preview.jpg',
    color: '#ff7a1a',
  },
  {
    name: 'LATAM Airlines',
    companyLogo: 'LATAM Airlines',
    logoClass: 'project-logo-latam',
    logoIcon: 'latam',
    role: 'Full Stack Java Developer',
    description: 'Delivered multiple airline technology initiatives from concept to production, designing and implementing Java services and data-driven systems with Spring, JPA, Oracle, MySQL and Docker in a high-availability enterprise environment.',
    tech: ['Java', 'Spring', 'JPA', 'Oracle', 'MySQL', 'Docker'],
    image: '/latam-preview.jpg',
    color: '#28c7ff',
  },
];
---

<Layout
  title='iOS Engineer Portfolio'
  pageTitle='iOS Engineer | Home'
  description='iOS Engineer specializing in Swift, SwiftUI, AI-assisted development, mobile architecture, and product engineering.'
>
  <main class='site-background'>
    <!-- Hero Section -->
    <section id='hero' class='p-6 md:p-12'>
      <div class='max-w-7xl mx-auto'>
        <Card color='#ffe01b'>
          <div class='grid lg:grid-cols-[1fr_auto] items-center gap-8 p-4 md:p-8'>
            <div class='flex flex-col items-start gap-6'>
              <h1 class='hero-name-title outfit font-bold'>
                <span class='hero-title-accent hero-name-text'>iOS Engineer</span>
              </h1>
              <p class='poppins text-xl md:text-2xl lg:text-3xl max-w-3xl'>
                I build native iOS products at the intersection of mobile engineering,
                AI-assisted development, architecture and product thinking.
                My work blends Swift, SwiftUI, GraphQL, observability, tooling and
                human-in-the-loop agent experimentation.
              </p>
              <div class='flex gap-4 flex-wrap'>
                <Button href='#projects'>
                  View My Work &rarr;
                </Button>
                <Button href='#contact'>
                  Get In Touch
                </Button>
              </div>
            </div>
            <button
              class='hero-profile-button'
              type='button'
              aria-label='Spin profile photo'
            >
              <img
                src='/oscar-profile.jpeg'
                alt='Oscar Cuadra Navarro'
                class='hero-profile-image'
                loading='eager'
              />
            </button>
          </div>
        </Card>
      </div>
    </section>

    <!-- About Section -->
    <section id='about' class='p-6 md:p-12'>
      <div class='max-w-7xl mx-auto grid md:grid-cols-2 gap-8'>
        <Card color='#8FCE00'>
          <div class='p-2 md:p-4'>
            <p class='section-kicker'>Profile</p>
            <h2 class='text-3xl md:text-5xl lg:text-6xl mb-6 dm-serif'>
              About Me
            </h2>
            <p class='poppins text-lg md:text-xl mb-6 max-w-xl'>
Hello, I'm Oscar, a Software Engineer from Chile with over 10 years of experience building scalable digital products, currently focused on iOS engineering.
I work on production mobile systems, UIKit to SwiftUI modernization, GraphQL/Apollo integrations, observability, architecture, and tooling that helps teams move with more confidence.
I am especially interested in the new shape of engineering work: how strong developers use AI agents, specifications, product context and human judgment to build better software.
            </p>
            <div class='grid sm:grid-cols-3 gap-3'>
              <div class='mini-stat'>
                <span class='mini-stat-value'>4+</span>
                <span class='mini-stat-label'>Years iOS</span>
              </div>
              <div class='mini-stat'>
                <span class='mini-stat-value'>AI</span>
                <span class='mini-stat-label'>Agent workflows</span>
              </div>
              <div class='mini-stat'>
                <span class='mini-stat-value'>UX</span>
                <span class='mini-stat-label'>Product thinking</span>
              </div>
            </div>
          </div>
        </Card>

        <Card color='#ff7a1a'>
          <div class='p-2 md:p-4'>
            <p class='section-kicker'>Craft</p>
            <h2 class='text-3xl md:text-5xl lg:text-6xl mb-6 dm-serif'>
              What I Do
            </h2>
            <div class='space-y-4'>
              <article class='capability-row'>
                <span class='capability-icon i-uil-mobile-android'></span>
                <div>
                  <h3 class='outfit text-2xl font-bold'>Product Engineering mindset</h3>
                  <p class='poppins text-base md:text-lg'>
                    Collaborating across engineering, product and UX to translate user needs into durable mobile experiences.
                  </p>
                </div>
              </article>
              <article class='capability-row'>
                <span class='capability-icon i-uil-brush-alt'></span>
                <div>
                  <h3 class='outfit text-2xl font-bold'>Scalable architecture & systems thinking</h3>
                  <p class='poppins text-base md:text-lg'>
                    Designing maintainable iOS systems, guiding UIKit to SwiftUI migrations, and integrating GraphQL/Apollo, REST and observability in production.
                  </p>
                </div>
              </article>
              <article class='capability-row'>
                <span class='capability-icon i-uil-tachometer-fast'></span>
                <div>
                  <h3 class='outfit text-2xl font-bold'>AI-enabled engineering</h3>
                  <p class='poppins text-base md:text-lg'>
                    Building with AI tools and coding agents as part of the development process, from specifications to implementation review.
                  </p>
                </div>
              </article>
            </div>
          </div>
        </Card>
      </div>
    </section>

    <!-- Focus Section -->
    <section id='focus' class='p-6 md:p-12'>
      <div class='max-w-7xl mx-auto'>
        <Card color='#f9fd5c'>
          <div class='p-2 md:p-4'>
            <p class='section-kicker'>Current Edge</p>
            <div class='focus-heading-grid'>
              <h2 class='text-3xl md:text-5xl lg:text-6xl dm-serif'>
                iOS + AI + Product Systems
              </h2>
              <p class='poppins text-lg md:text-xl'>
                The strongest engineering work now goes beyond writing clean code.
                I care about how teams use AI tools, agents, architecture and product judgment
                to raise the quality and velocity of what they ship.
              </p>
            </div>
            <div class='focus-grid'>
              {
                focusAreas.map((area) => (
                  <article class='focus-card'>
                    <span class:list={[area.icon, 'focus-card-icon']} />
                    <h3 class='outfit text-2xl font-bold'>{area.title}</h3>
                    <p class='poppins text-base md:text-lg'>{area.description}</p>
                  </article>
                ))
              }
            </div>
          </div>
        </Card>
      </div>
    </section>

    <!-- Skills Section -->
    <section id='skills' class='p-6 md:p-12'>
      <div class='max-w-7xl mx-auto'>
        <Card color='#28c7ff'>
          <h2 class='text-3xl md:text-5xl lg:text-6xl mb-8 dm-serif'>
            Skills & Technologies
          </h2>
          <div class='flex gap-3 flex-wrap'>
            {
              skills.map((skill) => (
                <Pill>
                  <span class='sanchez text-sm md:text-base'>{skill.name}</span>
                </Pill>
              ))
            }
          </div>
        </Card>
      </div>
    </section>

    <!-- Projects Section -->
    <section id='projects' class='p-6 md:p-12'>
      <div class='max-w-7xl mx-auto'>
        <h2 class='text-4xl md:text-6xl lg:text-7xl mb-8 dm-serif text-center'>
          Featured Projects
        </h2>
        <div class='grid md:grid-cols-2 lg:grid-cols-3 gap-8'>
          {
            projects.map((project) => (
              <Card color={project.color}>
                <div class='project-card-content'>
                  <div class:list={['project-company-logo', project.logoClass]}>
                    <span class:list={['project-logo-mark', `project-logo-mark-${project.logoIcon}`]}></span>
                    <span>{project.companyLogo}</span>
                  </div>
                  {project.image && (
                    <img
                      src={project.image}
                      alt={`${project.name} app screens`}
                      class='project-card-image'
                      loading='lazy'
                      onerror='this.remove()'
                    />
                  )}
                  <p class='project-role'>{project.role}</p>
                  <h3 class='text-2xl md:text-3xl lg:text-4xl mb-4 outfit font-bold'>
                    {project.name}
                  </h3>
                  <p class='poppins text-base md:text-lg mb-6 flex-grow'>
                    {project.description}
                  </p>
                  <div class='flex gap-2 flex-wrap mb-4'>
                    {project.tech.map((tech) => (
                      <Pill>
                        <span class='sanchez text-xs md:text-sm'>{tech}</span>
                      </Pill>
                    ))}
                  </div>
                </div>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section id='contact' class='p-6 md:p-12'>
      <div class='max-w-4xl mx-auto'>
        <Card color='#ee4cff'>
          <div class='text-center p-8'>
            <h2 class='text-4xl md:text-6xl lg:text-7xl mb-6 dm-serif'>
              Let's Work Together
            </h2>
            <p class='poppins text-lg md:text-xl mb-8 max-w-2xl mx-auto'>
              I'm always interested in hearing about new projects and opportunities.
              Whether you have a question or just want to say hi, feel free to reach out!
            </p>
            <div class='flex gap-4 justify-center flex-wrap'>
              <Button href='https://www.linkedin.com/in/oscar-cuadra-navarro-4bbb5743/?locale=en' target='_blank'>
                Contact on LinkedIn
              </Button>
              <Button href='https://www.linkedin.com/in/oscar-cuadra-navarro-4bbb5743/?locale=en' target='_blank'>
                LinkedIn
              </Button>
              <Button href='https://github.com/Rokkrs' target='_blank'>
                GitHub
              </Button>
            </div>
          </div>
        </Card>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const profileButton = document.querySelector('.hero-profile-button');

    profileButton?.addEventListener('click', () => {
      profileButton.classList.remove('is-spinning');
      window.requestAnimationFrame(() => {
        profileButton.classList.add('is-spinning');
      });
    });

    profileButton?.addEventListener('animationend', () => {
      profileButton.classList.remove('is-spinning');
    });
  });
</script>
